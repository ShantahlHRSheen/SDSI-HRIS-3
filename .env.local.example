# Copy this file to .env.local and fill in your Supabase project's values
# (Project Settings > API in the Supabase dashboard). Both of these are safe
# to expose to the browser — access control is enforced by the Row Level
# Security policies in supabase/schema.sql, not by keeping this key secret.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
